    "EnergyManagementSystem:Program": {
        "FrontEntry_HeaterControl": {
            "lines": [
                {
                    "program_line": "SET OAT_F = (OAT_F*1.8)+32"
                },
                {
                    "program_line": "IF OAT_F > 45"
                },
                {
                    "program_line": "SET FrontEntry_Coil = 0"
                },
                {
                    "program_line": "SET FrontEntry_Fan = 0"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET FrontEntry_Coil = 1"
                },
                {
                    "program_line": "SET FrontEntry_Fan = 1"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SET_Back_Space_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET Back_Space_LSr_IP=0.093*Back_Space_LSr/Back_Space_Area"
                },
                {
                    "program_line": "IF (Back_Space_Occ_Sensor <= 0) && (Back_Space_LSr_IP >= 0.02)"
                },
                {
                    "program_line": "SET Back_Space_Light_Actuator = 0.02*Back_Space_Area/0.09290304"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Back_Space_Light_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SET_Core_Retail_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET Core_Retail_LSr_IP=0.093*Core_Retail_LSr/Core_Retail_Area"
                },
                {
                    "program_line": "IF (Core_Retail_Occ_Sensor <= 0) && (Core_Retail_LSr_IP >= 0.02)"
                },
                {
                    "program_line": "SET Core_Retail_Light_Actuator = 0.02*Core_Retail_Area/0.09290304"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Core_Retail_Light_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SET_Front_Entry_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET Front_Entry_LSr_IP=0.093*Front_Entry_LSr/Front_Entry_Area"
                },
                {
                    "program_line": "IF (Front_Entry_Occ_Sensor <= 0) && (Front_Entry_LSr_IP >= 0.02)"
                },
                {
                    "program_line": "SET Front_Entry_Light_Actuator = 0.02*Front_Entry_Area/0.09290304"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Front_Entry_Light_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SET_Front_Retail_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET Front_Retail_LSr_IP=0.093*Front_Retail_LSr/Front_Retail_Area"
                },
                {
                    "program_line": "IF (Front_Retail_Occ_Sensor <= 0) && (Front_Retail_LSr_IP >= 0.02)"
                },
                {
                    "program_line": "SET Front_Retail_Light_Actuator = 0.02*Front_Retail_Area/0.09290304"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Front_Retail_Light_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SET_Point_Of_Sale_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET Point_Of_Sale_LSr_IP=0.093*Point_Of_Sale_LSr/Point_Of_Sale_Area"
                },
                {
                    "program_line": "IF (Point_Of_Sale_Occ_Sensor <= 0) && (Point_Of_Sale_LSr_IP >= 0.02)"
                },
                {
                    "program_line": "SET Point_Of_Sale_Light_Actuator = 0.02*Point_Of_Sale_Area/0.09290304"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Point_Of_Sale_Light_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        }
    },
