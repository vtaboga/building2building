    "EnergyManagementSystem:Program": {
        "air_source_heat_pump_supply_fan_disaggregate_program": {
            "lines": [
                {
                    "program_line": "Set air_source_heat_pump_supply_fan_clg = 0"
                },
                {
                    "program_line": "Set air_source_heat_pump_supply_fan_primary_htg = 0"
                },
                {
                    "program_line": "Set air_source_heat_pump_supply_fan_backup_htg = 0"
                },
                {
                    "program_line": "If air_source_heat_pump_clg_coil_s > 0"
                },
                {
                    "program_line": "Set air_source_heat_pump_supply_fan_clg = air_source_heat_pump_supply_fan_s"
                },
                {
                    "program_line": "ElseIf air_source_heat_pump_htg_coil_s > 0 && (air_source_heat_pump_backup_htg_coil_s > 0)"
                },
                {
                    "program_line": "Set air_source_heat_pump_supply_fan_primary_htg = air_source_heat_pump_supply_fan_s * air_source_heat_pump_htg_coil_s / (air_source_heat_pump_htg_coil_s + air_source_heat_pump_backup_htg_coil_s)"
                },
                {
                    "program_line": "Set air_source_heat_pump_supply_fan_backup_htg = air_source_heat_pump_supply_fan_s * air_source_heat_pump_backup_htg_coil_s / (air_source_heat_pump_htg_coil_s + air_source_heat_pump_backup_htg_coil_s)"
                },
                {
                    "program_line": "ElseIf air_source_heat_pump_htg_coil_s > 0"
                },
                {
                    "program_line": "Set air_source_heat_pump_supply_fan_primary_htg = air_source_heat_pump_supply_fan_s"
                },
                {
                    "program_line": "Else"
                },
                {
                    "program_line": "Set air_source_heat_pump_supply_fan_backup_htg = air_source_heat_pump_supply_fan_s"
                },
                {
                    "program_line": "EndIf"
                }
            ]
        },
