                {
                    "program_line": "Set p_m = 0.14"
                },
                {
                    "program_line": "Set p_s = 0.22"
                },
                {
                    "program_line": "Set s_m = 270"
                },
                {
                    "program_line": "Set s_s = 370"
                },
                {
                    "program_line": "Set z_m = 9.99744"
                },
                {
                    "program_line": "Set z_s = 2.9718"
                },
                {
                    "program_line": "Set f_t = (((s_m/z_m)^p_m)*((z_s/s_s)^p_s))"
                },
                {
                    "program_line": "Set Tdiff = tin_s-tout_s"
                },
                {
                    "program_line": "Set dT = @Abs Tdiff"
                },
                {
                    "program_line": "Set c = 0.0656"
                },
                {
                    "program_line": "Set Cs = 0.066"
                },
                {
                    "program_line": "Set Cw = 0.1664"
                },
                {
                    "program_line": "Set n = 0.65"
                },
                {
                    "program_line": "Set sft = (f_t*0.5)"
                },
                {
                    "program_line": "Set temp1 = ((c*Cw)*((sft*site_vw_s)^(2*n)))^2"
                },
                {
                    "program_line": "Set Qinf = (((c*Cs*(dT^n))^2)+temp1)^0.5"
                },
                {
                    "program_line": "Set Qinf = (@Max Qinf 0)"
                },
                {
                    "program_line": "Set mech_vent_house_fan_sensible_load_act = 0.0"
                },
                {
                    "program_line": "Set mech_vent_house_fan_latent_load_act = 0.0"
                },
                {
                    "program_line": "Set OASupInPb = out_pb_s"
                },
                {
                    "program_line": "Set OASupInTemp = tout_s"
                },
                {
                    "program_line": "Set OASupInW = out_wt_s"
                },
                {
                    "program_line": "Set OASupRho = (@RhoAirFnPbTdbW OASupInPb OASupInTemp OASupInW)"
                },
                {
                    "program_line": "Set OASupCp = (@CpAirFnW OASupInW)"
                },
                {
                    "program_line": "Set OASupInEnth = (@HFnTdbW OASupInTemp OASupInW)"
                },
                {
                    "program_line": "Set ZoneTemp = tin_s"
                },
                {
                    "program_line": "Set ZoneW = win_s"
                },
                {
                    "program_line": "Set ZoneCp = (@CpAirFnW ZoneW)"
                },
                {
                    "program_line": "Set ZoneAirEnth = (@HFnTdbW ZoneTemp ZoneW)"
                },
                {
                    "program_line": "Set mech_vent_house_fan_cfis_act = 0.0"
                },
                {
                    "program_line": "Set QWHV_cfis_sup = 0.0"
                },
                {
                    "program_line": "Set QWHV_cfis_suppl_sup = 0.0"
                },
                {
                    "program_line": "Set QWHV_cfis_suppl_exh = 0.0"
                },
                {
                    "program_line": "Set Qrange = 0"
                },
                {
                    "program_line": "Set Qrange = Qrange + 0.04719 * mech_vent_range_fan_0_sch_s"
                },
                {
                    "program_line": "Set Qbath = 0"
                },
                {
                    "program_line": "Set Qbath = Qbath + 0.04719 * mech_vent_bath_fan_0_sch_s"
                },
                {
                    "program_line": "Set Qdryer = 0"
                },
                {
                    "program_line": "Set Qdryer = Qdryer + 0.08592 * clothes_dryer_exhaust_0_sch_s"
                },
                {
                    "program_line": "Set QWHV_sup = 0.0"
                },
                {
                    "program_line": "Set QWHV_exh = 0.0"
                },
                {
                    "program_line": "Set Qsupply = QWHV_sup + QWHV_cfis_sup + QWHV_cfis_suppl_sup"
                },
                {
                    "program_line": "Set Qexhaust = Qrange + Qbath + Qdryer + QWHV_exh + QWHV_cfis_suppl_exh"
                },
                {
                    "program_line": "Set Qfan = (@Max Qexhaust Qsupply)"
                },
                {
                    "program_line": "Set Qducts = 0"
                },
                {
                    "program_line": "If Qducts < 0"
                },
                {
                    "program_line": "Set Qsupply = Qsupply - Qducts"
                },
                {
                    "program_line": "Else"
                },
                {
                    "program_line": "Set Qexhaust = Qexhaust + Qducts"
                },
                {
                    "program_line": "EndIf"
                },
                {
                    "program_line": "Set Qfan_with_ducts = (@Max Qexhaust Qsupply)"
                },
                {
                    "program_line": "Set Qimb = (@Abs (Qsupply - Qexhaust))"
                },
                {
                    "program_line": "If Qinf + Qimb > 0"
                },
                {
                    "program_line": "Set Qtot = Qfan_with_ducts + (Qinf^2) / (Qinf + Qimb)"
                },
                {
                    "program_line": "Else"
                },
                {
                    "program_line": "Set Qtot = Qfan_with_ducts"
                },
                {
                    "program_line": "EndIf"
                },
                {
                    "program_line": "Set Qinf_adj = Qtot - Qfan"
                },
                {
                    "program_line": "Set infil_flow_act = Qinf_adj"
                },
                {
                    "program_line": "Set infil_program_Qinf = Qinf_adj"
                },
                {
                    "program_line": "Set infil_program_Qfan = Qfan"
                },
                {
                    "program_line": "Set Qload = Qfan"
                },
                {
                    "program_line": "Set Effectiveness_Sens = 0.0"
                },
                {
                    "program_line": "Set Effectiveness_Lat = 0.0"
                },
                {
                    "program_line": "Set Fan_MFR = Qload * OASupRho"
                },
                {
                    "program_line": "Set ZoneInEnth = OASupInEnth"
                },
                {
                    "program_line": "Set ZoneInTemp = OASupInTemp"
                },
                {
                    "program_line": "Set FanTotalToCond = Fan_MFR * (ZoneInEnth - ZoneAirEnth)"
                },
                {
                    "program_line": "Set FanSensToCond = Fan_MFR * ZoneCp * (ZoneInTemp - ZoneTemp)"
                },
                {
                    "program_line": "Set FanLatToCond = FanTotalToCond - FanSensToCond"
                },
                {
                    "program_line": "Set mech_vent_house_fan_sensible_load_act = mech_vent_house_fan_sensible_load_act + FanSensToCond"
                },
                {
                    "program_line": "Set mech_vent_house_fan_latent_load_act = mech_vent_house_fan_latent_load_act + FanLatToCond"
                }
            ]
        },
        "natural_vent_program": {
            "lines": [
                {
                    "program_line": "Set Tin = tin_s"
                },
                {
                    "program_line": "Set Tout = tout_s"
                },
                {
                    "program_line": "Set Wout = out_wt_s"
                },
                {
                    "program_line": "Set Pbar = out_pb_s"
                },
                {
                    "program_line": "Set Phiout = (@RhFnTdbWPb Tout Wout Pbar)"
                },
                {
                    "program_line": "Set MaxHR = 0.0115"
                },
                {
                    "program_line": "Set Tnvsp = (htg_sp_s + clg_sp_s) / 2"
                },
                {
                    "program_line": "Set NVavail = natural_vent_s"
                },
                {
                    "program_line": "Set ClgSsnAvail = cool_season"
                },
                {
                    "program_line": "Set Qnv = 0"
                },
                {
                    "program_line": "Set Qwhf = 0"
                },
                {
                    "program_line": "Set whole_house_fan_mix_act = 0"
                },
                {
                    "program_line": "Set whole_house_fan_act = 0"
                },
                {
                    "program_line": "If ((Wout < MaxHR) && (Tin > Tout) && (Tin > Tnvsp) && (ClgSsnAvail > 0))"
                },
                {
                    "program_line": "Set WHF_Flow = 0"
                },
                {
                    "program_line": "Set Adj = (Tin-Tnvsp)/(Tin-Tout)"
                },
                {
                    "program_line": "Set Adj = (@Min Adj 1)"
                },
                {
                    "program_line": "Set Adj = (@Max Adj 0)"
                },
                {
                    "program_line": "If (WHF_Flow > 0)"
                },
                {
                    "program_line": "Set Qwhf = WHF_Flow*Adj"
                },
                {
                    "program_line": "Set whole_house_fan_mix_act = WHF_Flow*Adj"
                },
                {
                    "program_line": "Set WHF_W = 0"
                },
                {
                    "program_line": "Set whole_house_fan_act = WHF_W*Adj"
                },
                {
                    "program_line": "ElseIf (NVavail > 0)"
                },
                {
                    "program_line": "Set NVArea = 4354.662774528"
                },
                {
                    "program_line": "Set Cs = 0.00010930442197923115"
                },
                {
                    "program_line": "Set Cw = 7.138622473985284e-05"
                },
                {
                    "program_line": "Set Tdiff = Tin-Tout"
                },
                {
                    "program_line": "Set dT = (@Abs Tdiff)"
                },
                {
                    "program_line": "Set Vwind = site_vw_s"
                },
                {
                    "program_line": "Set SGNV = NVArea*Adj*((((Cs*dT)+(Cw*(Vwind^2)))^0.5)/1000)"
                },
                {
                    "program_line": "Set MaxNV = 2.1369780228096005"
                },
                {
                    "program_line": "Set Qnv = (@Min SGNV MaxNV)"
                },
                {
                    "program_line": "EndIf"
                },
                {
                    "program_line": "EndIf"
                },
                {
                    "program_line": "Set natural_vent_flow_act = Qnv"
                },
                {
                    "program_line": "Set whole_house_fan_flow_act = Qwhf"
                },
                {
                    "program_line": "Set natural_vent_program_Qnv = Qnv"
                },
                {
                    "program_line": "Set natural_vent_program_Qwhf = Qwhf"
                }
            ]
        },
        "total_airflows_program": {
            "lines": [
                {
                    "program_line": "Set total_infil_flow_rate = 0"
                },
                {
                    "program_line": "Set total_mechvent_flow_rate = 0"
                },
                {
                    "program_line": "Set total_natvent_flow_rate = 0"
                },
                {
                    "program_line": "Set total_whf_flow_rate = 0"
                },
                {
                    "program_line": "Set total_infil_flow_rate = total_infil_flow_rate + (infil_program_Qinf * 1)"
                },
                {
                    "program_line": "Set total_mechvent_flow_rate = total_mechvent_flow_rate + (infil_program_Qfan * 1)"
                },
                {
                    "program_line": "Set total_natvent_flow_rate = total_natvent_flow_rate + (natural_vent_program_Qnv * 1)"
                },
                {
                    "program_line": "Set total_whf_flow_rate = total_whf_flow_rate + (natural_vent_program_Qwhf * 1)"
                }
            ]
        },
        "total_loads_program": {
            "lines": [
                {
                    "program_line": "Set loads_htg_tot = 0"
                },
                {
                    "program_line": "Set loads_clg_tot = 0"
                },
                {
                    "program_line": "If htg_load_cond > 0"
                },
                {
                    "program_line": "Set loads_htg_tot = loads_htg_tot + (htg_load_cond - clg_load_cond) * 1.0"
                },
                {
                    "program_line": "EndIf"
                },
                {
                    "program_line": "Set loads_htg_tot = (@Max loads_htg_tot 0)"
                },
                {
                    "program_line": "If clg_load_cond > 0"
                },
                {
                    "program_line": "Set loads_clg_tot = loads_clg_tot + (clg_load_cond - htg_load_cond) * 1.0"
                },
                {
                    "program_line": "EndIf"
                },
                {
                    "program_line": "Set loads_clg_tot = (@Max loads_clg_tot 0)"
                }
            ]
        },
        "unmet_hours_program": {
            "lines": [
                {
                    "program_line": "Set htg_unmet_hours = 0"
                },
                {
                    "program_line": "Set clg_unmet_hours = 0"
                },
                {
                    "program_line": "Set unit_htg_unmet_hours = 0"
                },
                {
                    "program_line": "If ((DayOfYear >= 1) && (DayOfYear <= 365))"
                },
                {
                    "program_line": "Set unit_htg_unmet_hours = unit_htg_unmet_hours + conditioned_space_htg_unmet_s"
                },
                {
                    "program_line": "If unit_htg_unmet_hours > htg_unmet_hours"
                },
                {
                    "program_line": "Set htg_unmet_hours = unit_htg_unmet_hours"
                },
                {
                    "program_line": "EndIf"
                },
                {
                    "program_line": "EndIf"
                },
                {
                    "program_line": "Set unit_clg_unmet_hours = 0"
                },
                {
                    "program_line": "If ((DayOfYear >= 152) && (DayOfYear <= 243))"
                },
                {
                    "program_line": "Set unit_clg_unmet_hours = unit_clg_unmet_hours + conditioned_space_clg_unmet_s"
                },
                {
                    "program_line": "If unit_clg_unmet_hours > clg_unmet_hours"
                },
                {
                    "program_line": "Set clg_unmet_hours = unit_clg_unmet_hours"
                },
                {
                    "program_line": "EndIf"
                },
                {
                    "program_line": "EndIf"
                }
            ]
        },
        "water_heater_EC_adj": {
            "lines": [
                {
                    "program_line": "If WarmupFlag == 0"
                },
                {
                    "program_line": "Set dhw_e_cons = water_heater_energy + water_heater_on_cycle_parasitic + water_heater_off_cycle_parasitic"
                },
                {
                    "program_line": "Set water_heater_ec_adj_act = 0.0 * dhw_e_cons / 1"
                },
                {
                    "program_line": "EndIf"
                }
            ]
        }
    },
