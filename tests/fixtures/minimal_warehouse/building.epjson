    "EnergyManagementSystem:Program": {
        "SET_Zone1_Office_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET Zone1_Office_LSr_IP=0.093*Zone1_Office_LSr/Zone1_Office_Area"
                },
                {
                    "program_line": "IF (Zone1_Office_Occ_Sensor <= 0) && (Zone1_Office_LSr_IP >= 0.02)"
                },
                {
                    "program_line": "SET Zone1_Office_Light_Actuator = 0.02*Zone1_Office_Area/0.09290304"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Zone1_Office_Light_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SET_Zone2_Fine_Storage_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET Zone2_Fine_Storage_LSr_IP=0.093*Zone2_Fine_Storage_LSr/Zone2_Fine_Storage_Area"
                },
                {
                    "program_line": "IF (Zone1_Office_Occ_Sensor <= 0) && (Zone2_Fine_Storage_LSr_IP >= 0.02)"
                },
                {
                    "program_line": "SET Zone2_Fine_Storage_Light_Actuator = 0.02*Zone2_Fine_Storage_Area/0.09290304"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Zone2_Fine_Storage_Light_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SET_Zone3_Bulk_Storage_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET Zone3_Bulk_Storage_LSr_IP=0.093*Zone3_Bulk_Storage_LSr/Zone3_Bulk_Storage_Area"
                },
                {
                    "program_line": "IF (Zone1_Office_Occ_Sensor <= 0) && (Zone3_Bulk_Storage_LSr_IP >= 0.02)"
                },
                {
                    "program_line": "SET Zone3_Bulk_Storage_Light_Actuator = 0.02*Zone3_Bulk_Storage_Area/0.09290304"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Zone3_Bulk_Storage_Light_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        }
    },
