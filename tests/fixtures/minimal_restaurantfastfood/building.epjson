    "EnergyManagementSystem:Program": {
        "SET_Dining_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET Dining_LSr_IP=0.093*Dining_LSr/Dining_Area"
                },
                {
                    "program_line": "IF (Dining_Occ_Sensor <= 0) && (Dining_LSr_IP >= 0.02)"
                },
                {
                    "program_line": "SET Dining_Light_Actuator = 0.02*Dining_Area/0.09290304"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Dining_Light_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        },
        "SET_Kitchen_Light_EMS_Program": {
            "lines": [
                {
                    "program_line": "SET Kitchen_LSr_IP=0.093*Kitchen_LSr/Kitchen_Area"
                },
                {
                    "program_line": "IF (Kitchen_Occ_Sensor <= 0) && (Kitchen_LSr_IP >= 0.02)"
                },
                {
                    "program_line": "SET Kitchen_Light_Actuator = 0.02*Kitchen_Area/0.09290304"
                },
                {
                    "program_line": "ELSE"
                },
                {
                    "program_line": "SET Kitchen_Light_Actuator = NULL"
                },
                {
                    "program_line": "ENDIF"
                }
            ]
        }
    },
    "EnergyManagementSystem:ProgramCallingManager": {
        "SET_Dining_Light_EMS_Program_Prog_Manager": {
